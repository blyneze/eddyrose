# ─────────────────────────────────────────────────────────────────────────────
# Eddyrose Academy — Frontend Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Express backend (local or Render URL)
BACKEND_URL="http://localhost:4000"

# Shared secret between this frontend and the backend.
# Must match the INTERNAL_API_SECRET set in the backend exactly.
INTERNAL_API_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────────────────────────────────────

# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Full public URL of the app (no trailing slash)
# Local development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"
