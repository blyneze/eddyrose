# ─────────────────────────────────────────────────────────────────────────────
# Eddyrose Academy — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, Railway, or local)
# For Neon pooled connections, append ?pgbouncer=true&channel_binding=require
DATABASE_URL=""

# ─────────────────────────────────────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────────────────────────────────────

# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Full public URL of the app (no trailing slash)
# Local development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"
