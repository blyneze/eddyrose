datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPERADMIN
  TEACHER
  PARENT
}

enum Visibility {
  WEBSITE_ONLY
  DASHBOARD_ONLY
  BOTH
}

enum ResultStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
}

model User {
  id        String   @id @default(cuid())
  loginId   String   @unique
  password  String
  role      Role
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile TeacherProfile?
  parentProfile  ParentProfile?
  
  // Content relation
  announcements Announcement[]
  events        Event[]
}

model TeacherProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments TeacherClassAssignment[]
}

model ParentProfile {
  id       String   @id @default(cuid())
  userId   String   @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  students ParentStudentLink[]
}

model Student {
  id                 String   @id @default(cuid())
  name               String
  registrationNumber String   @unique
  sex                String?  // e.g. "Male", "Female"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  parents            ParentStudentLink[]
  enrollments        StudentEnrollment[]
  resultSheets       ResultSheet[]
}

model ParentStudentLink {
  id              String         @id @default(cuid())
  parentProfileId String
  studentId       String
  parentProfile   ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentProfileId, studentId])
}

model Session {
  id           String              @id @default(cuid())
  name         String              @unique // e.g. "2025/2026"
  isCurrent    Boolean             @default(false)
  enrollments  StudentEnrollment[]
  resultSheets ResultSheet[]
}

model Term {
  id           String              @id @default(cuid())
  name         String              @unique // e.g. "First Term"
  isCurrent    Boolean             @default(false)
  enrollments  StudentEnrollment[]
  resultSheets ResultSheet[]
}

model Class {
  id              String   @id @default(cuid())
  name            String   @unique // e.g. "Transition", "Reception", "Grade 1"
  orderIndex      Int      @default(0) // Used for sorting
  
  enrollments     StudentEnrollment[]
  teacherAssigns  TeacherClassAssignment[]
  resultSheets    ResultSheet[]
  subjects        ClassSubject[]
}

// Global subject catalog
model Subject {
  id          String         @id @default(cuid())
  name        String         @unique
  classLinks  ClassSubject[]
}

// Subjects available in a given class
model ClassSubject {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  entries   ResultEntry[]

  @@unique([classId, subjectId])
}

model StudentEnrollment {
  id        String  @id @default(cuid())
  studentId String
  sessionId String
  termId    String
  classId   String

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  term      Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId, termId])
}

model TeacherClassAssignment {
  id               String         @id @default(cuid())
  teacherProfileId String
  classId          String
  
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  class            Class          @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([teacherProfileId, classId])
}

model ResultSheet {
  id        String       @id @default(cuid())
  studentId String
  sessionId String
  termId    String
  classId   String
  status    ResultStatus @default(DRAFT)
  
  // Manual Fields (Teacher/Admin controlled)
  teacherComment    String?
  principalComment  String?
  closingDate       DateTime?
  resumptionDate    DateTime?
  affectiveDomain   Json?     // Checkbox-style traits: { "punctuality": 4, "neatness": 5, ... }
  
  student   Student      @relation(fields: [studentId], references: [id])
  session   Session      @relation(fields: [sessionId], references: [id])
  term      Term         @relation(fields: [termId], references: [id])
  class     Class        @relation(fields: [classId], references: [id])
  
  entries   ResultEntry[]

  @@unique([studentId, sessionId, termId])
}

model ResultEntry {
  id             String       @id @default(cuid())
  resultSheetId  String
  classSubjectId String
  testScore      Float?       // Continuous Assessment (e.g. 0-30)
  examScore      Float?       // Examination (e.g. 0-70)
  
  // Note: totalScore, grade, and remark are calculated at runtime by the service

  resultSheet    ResultSheet  @relation(fields: [resultSheetId], references: [id], onDelete: Cascade)
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id])

  @@unique([resultSheetId, classSubjectId])
}

model Announcement {
  id          String     @id @default(cuid())
  title       String
  summary     String?
  content     String
  visibility  Visibility @default(BOTH)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
}

model Event {
  id          String     @id @default(cuid())
  title       String
  description String?
  date        DateTime
  time        String?
  venue       String?
  visibility  Visibility @default(BOTH)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
}
